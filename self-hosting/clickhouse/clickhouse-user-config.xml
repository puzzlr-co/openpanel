<clickhouse>
    <profiles>
        <default>
            <log_queries>0</log_queries>
            <log_query_threads>0</log_query_threads>
            <!-- Per-query memory cap: prevents a single heavy query (e.g. user
                 journey groupArray) from taking down the whole server. -->
            <max_memory_usage>6000000000</max_memory_usage>
            <!-- Spill large GROUP BY / ORDER BY to disk well before the cap so
                 heavy-but-legitimate queries complete instead of failing. -->
            <max_bytes_before_external_group_by>3000000000</max_bytes_before_external_group_by>
            <max_bytes_before_external_sort>3000000000</max_bytes_before_external_sort>
        </default>
    </profiles>
</clickhouse>